# Pidgin Configuration Example
# Copy to pidgin.yaml and customize as needed

conversation:
  # Checkpoint settings
  checkpoint:
    enabled: true
    auto_save_interval: 10  # Save checkpoint every N turns
    
  # Attractor detection settings (structural patterns ONLY)
  attractor_detection:
    enabled: true
    check_interval: 5     # Check every N turns
    window_size: 10       # Look at last N messages
    threshold: 3          # Trigger after N repetitions
    on_detection: "stop"  # Options: stop, pause, log

# Token management settings
token_management:
  enabled: true
  warning_threshold: 5         # Warn when X exchanges remaining (rate limits)
  auto_pause_threshold: 2      # Auto-pause when X exchanges remaining (rate limits) 
  show_metrics: true           # Display rate limit usage in conversation
  rate_warning_threshold: 90   # Only warn about rate limits at 90%+ usage
  rate_pause_threshold: 95     # Only pause for rate limits at 95%+ usage
  show_rate_usage: false       # De-emphasize rate limit tracking in display

# Context window management settings
context_management:
  enabled: true
  warning_threshold: 80    # Warn at 80% context capacity
  auto_pause_threshold: 95 # Auto-pause at 95% context capacity
  show_usage: true         # Display context usage in conversation

# Experiment profiles
experiments:
  # Profile for unattended experiments
  unattended:
    attractor_detection:
      on_detection: "stop"
      threshold: 2      # More aggressive detection
      window_size: 8    # Smaller window for faster detection
  
  # Profile for baseline experiments (no intervention)
  baseline:
    attractor_detection:
      enabled: false
      
  # Profile for sensitive detection
  sensitive:
    attractor_detection:
      threshold: 2
      window_size: 6
      check_interval: 3  # Check more frequently